{
    "name": "odinns/laravel-wayback-machine",
    "description": "Restore public Wayback Machine captures from Laravel into local files.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "archive",
        "internet-archive",
        "laravel",
        "wayback-machine"
    ],
    "homepage": "https://github.com/odinns/laravel-wayback-machine",
    "authors": [
        {
            "name": "Odinn Sorensen"
        }
    ],
    "support": {
        "issues": "https://github.com/odinns/laravel-wayback-machine/issues",
        "source": "https://github.com/odinns/laravel-wayback-machine"
    },
    "autoload": {
        "psr-4": {
            "Odinns\\LaravelWaybackMachine\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Odinns\\LaravelWaybackMachine\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "8.3.* || 8.4.*",
        "illuminate/console": "^12.0 || ^13.0",
        "illuminate/filesystem": "^12.0 || ^13.0",
        "illuminate/http": "^12.0 || ^13.0",
        "illuminate/support": "^12.0 || ^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "odinns/coding-style": "^1.0",
        "odinns/phpstan-pest-this": "^1.0",
        "orchestra/testbench": "^10.0 || ^11.0",
        "pestphp/pest": "^3.0 || ^4.0",
        "pestphp/pest-plugin-laravel": "^3.0 || ^4.0",
        "rector/rector": "^2.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Odinns\\LaravelWaybackMachine\\WaybackMachineServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "pest",
        "test:types": "phpstan analyse",
        "test:refactor": "rector process --dry-run",
        "test:all": [
            "@test",
            "@test:types",
            "@test:refactor"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
